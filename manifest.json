{
  "manifest_version": 3,
  "name": "Proventure Maps Grabber",
  "version": "1.1",
  "description": "Extracts active Google Maps DOM records into Google Sheets.",
  "permissions": ["activeTab", "scripting", "storage", "notifications", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon.svg",
    "48": "icon.svg",
    "128": "icon.svg"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.svg"
  }
}